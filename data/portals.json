{
  "https://scholarships.gov.in": {
    "fields": {
      "name": "input[name='studentName']",
      "caste": "select[name='casteCategory']",
      "income": "input[name='annualIncome']",
      "course": "input[name='courseName']",
      "percentage": "input[name='lastPercentage']"
    },
    "submit": "button[type='submit']"
  },
  "https://tnscholarship.net": {
    "fields": {
      "name": "#student_name",
      "caste": "#caste",
      "income": "#income",
      "course": "#course",
      "percentage": "#percentage"
    },
    "submit": "button.submit"
  },
  "https://egrantz.tn.gov.in": {
    "fields": {
      "name": "input[name='applicantName']",
      "caste": "select[name='community']",
      "income": "input[name='annualIncome']",
      "course": "input[name='course']",
      "percentage": "input[name='percentage']"
    },
    "submit": "button#save"
  }
}
