{
  "manifest_version": 3,
  "name": "Athena",
  "version": "0.1.0",
  "description": "Tamil-first Scholarship Agent",
  "permissions": ["storage", "activeTab", "scripting", "alarms", "tabs", "sidePanel"],
  "host_permissions": ["http://localhost:11434/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["agent/filler.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:11434"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Athena",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
